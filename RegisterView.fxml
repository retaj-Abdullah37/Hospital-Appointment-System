<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<!--
    BrowseDoctors.fxml - Browse and filter doctors
    Uses BorderPane layout
-->

<BorderPane xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="projectcode1.controllers.BrowseDoctorsController">

    <!-- Top: Title and Filter -->
    <top>
        <VBox spacing="15.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>

            <Label text="Browse Doctors">
                <font>
                    <Font name="System Bold" size="24.0" />
                </font>
            </Label>

            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Label text="Filter by Specialty:">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
                <ComboBox fx:id="specialtyCombo" prefWidth="200.0" />
                <Button text="Show All" onAction="#handleShowAll" />
            </HBox>
        </VBox>
    </top>

    <!-- Center: Doctors Table -->
    <center>
        <TableView fx:id="doctorsTable">
            <columns>
                <TableColumn fx:id="nameColumn" text="Doctor Name" prefWidth="200.0" />
                <TableColumn fx:id="specialtyColumn" text="Specialty" prefWidth="200.0" />
                <TableColumn fx:id="experienceColumn" text="Experience (Years)" prefWidth="150.0" />
                <TableColumn fx:id="emailColumn" text="Email" prefWidth="200.0" />
            </columns>
        </TableView>
    </center>

    <!-- Bottom: Buttons -->
    <bottom>
        <HBox spacing="10.0" alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>

            <Button text="Book Appointment" onAction="#handleBookAppointment"
                    prefWidth="150.0" prefHeight="40.0"
                    style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px;" />

            <Button text="Back to Dashboard" onAction="#handleBack"
                    prefWidth="150.0" prefHeight="40.0"
                    style="-fx-background-color: #757575; -fx-text-fill: white; -fx-font-size: 14px;" />
        </HBox>
    </bottom>

</BorderPane>
