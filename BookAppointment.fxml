package projectcode1;

import javafx.application.Application;
import javafx.fxml.FXMLLoader;
import javafx.scene.Parent;
import javafx.scene.Scene;
import javafx.stage.Stage;
import projectcode1.dao.DatabaseConnection;

/**
 * Main Application Class - Hospital Appointment System
 * Demonstrates: JavaFX Application, Exception Handling
 *
 * @author CS313 Term Project
 */
public class ProjectCode1 extends Application {

    @Override
    public void start(Stage primaryStage) {
        try {
            // Test database connection on startup
            System.out.println("========================================");
            System.out.println("Hospital Appointment System Starting...");
            System.out.println("========================================");

            DatabaseConnection dbConnection = DatabaseConnection.getInstance();
            if (dbConnection.testConnection()) {
                System.out.println("Database connection successful!");
            } else {
                System.err.println("Database connection failed!");
            }

            // Load Login View (FXML)
            FXMLLoader loader = new FXMLLoader(getClass().getResource("/projectcode1/views/LoginView.fxml"));
            Parent root = loader.load();

            // Create and setup the scene
            Scene scene = new Scene(root);

            primaryStage.setTitle("Hospital Appointment System - Login");
            primaryStage.setScene(scene);
            primaryStage.setResizable(false);
            primaryStage.show();

            System.out.println("Application started successfully!");

        } catch (Exception e) {
            System.err.println("Error starting application!");
            e.printStackTrace();
        }
    }

    @Override
    public void stop() {
        // Cleanup when application closes
        System.out.println("Closing application...");
        DatabaseConnection.getInstance().closeConnection();
        System.out.println("Application closed.");
    }

    /**
     * Main method - Application entry point
     * @param args Command line arguments
     */
    public static void main(String[] args) {
        launch(args);
    }
}
